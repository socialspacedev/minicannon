{
  "name": "minicannon",
  "version": "2.0.0",
  "description": "Make this build please",
  "main": "index.js",
  "scripts": {
    "dev": "run-p dev:*",
    "go!": "NODE_ENV=production run-s clean css eleventy",
    "clean": "rimraf public",
    "css": "npx tailwindcss -i src/_css/site.css -o public/css/style.css --minify",
    "eleventy": "npx @11ty/eleventy",
    "dev:css": "npx tailwindcss -i src/_css/site.css -o public/css/style.css --watch --minify",
    "dev:11ty": "eleventy --serve --watch"
  },
  "keywords": [
    "Website",
    "Blog",
    "11ty",
    "Tailwindcss",
    "SEO",
    "CloudCannon"
  ],
  "author": "Andrew Long",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@tailwindcss/typography": "^0.5.2",
    "html-minifier-terser": "^7.2.0",
    "luxon": "^3.7.2",
    "npm-run-all2": "^7.0.2",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "@11ty/eleventy-fetch": "^5.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "eleventy-plugin-time-to-read": "^1.3.0",
    "eleventy-plugin-youtube-embed": "^1.13.2",
    "pagefind": "^1.5.2"
  }
}
