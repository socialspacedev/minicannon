<!-- Automated Title -->
{% assign pageTitle = title | default: '' -%}
{% assign pageTitle = pageTitle | append: ' - ' | append: meta.siteName -%}

<!-- Automatic Description -->
{% assign pageDescription = description | default: '' -%}
{% assign pageDescription = pageDescription | default: meta.siteDescription -%}

{% include "head.liquid" %}
    <!-- Schema image — same fallback chain as the social share image -->
    {%- assign ldImage = thumbnail -%}
    {%- if ldImage == blank and a_certain_sound.hero_image -%}{%- assign ldImage = a_certain_sound.hero_image -%}{%- endif -%}
    {%- if ldImage == blank -%}{%- assign ldImage = meta.defaultImage -%}{%- endif -%}
    <!-- Schema JSON-LD -->
    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "BlogPosting",
            "mainEntityOfPage": {
                "@type": "WebPage",
                "@id": "{{ meta.url }}{{ page.url }}"
            },
            "headline": "{{ title | escape }}",
            "url": "{{ meta.url }}{{ page.url }}",
            "datePublished": "{{ page.date | date: '%Y-%m-%dT%H:%M:%SZ' }}",
            "dateModified": "{{ page.date | date: '%Y-%m-%dT%H:%M:%SZ' }}",
            "author": {
                "@type": "Person",
                "name": "{{ meta.authorName }}",
                "url": "{{ meta.url }}"
            },
            "publisher": {
                "@type": "Organization",
                "name": "{{ meta.siteName }}",
                "url": "{{ meta.url }}"
            },
            "description": "{{ pageDescription | escape }}"{% if ldImage %},
            "image": {
                "@type": "ImageObject",
                "url": "{{ meta.url }}{{ ldImage }}"
            }{% endif %}
        }
    </script>
</head>
<!-- End Head - Article -->
