{% comment %}
 Automated Title
{% endcomment %}
{% assign pageTitle = title | default: '' -%}{% assign pageTitle = pageTitle | append: ' - ' | append: meta.siteName -%}

{% comment %}
  Automated Description
{% endcomment %}
{% assign pageDescription = description | default: '' -%}{% assign pageDescription = pageDescription | default: '' -%}

{% comment %}
  Page URL
{% endcomment %}
{% assign pageUrls = meta.url | append: ' ' | append: page.url -%}

{% comment %}
  Start Head
{% endcomment %}
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  {% comment %}
    About Page
  {% endcomment %}
  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ pageDescription }}" />
  <meta name="keywords" content="{{ pageKeyword }}" />
  <meta name="creation_Date" content="{{ meta.creationDate }}" />

    {% comment %}
      Robot
    {% endcomment %}
  <meta name="robots" content="{{ meta.robots }}" />

    {% comment %}
      Author
    {% endcomment %}
  <meta name="author" content="{{ meta.authorName }}" />

    {% comment %}
      Fonts
    {% endcomment %}
  <style>
@font-face {
  font-display: optional;
  font-family: 'Roboto Serif';
  font-style: normal;
  font-weight: 300;
  font-stretch: 100%;
  src: url('/fonts/roboto-serif-v13-latin_latin-ext-300.woff2') format('woff2');
}
@font-face {
  font-display: optional;
  font-family: 'Roboto Serif';
  font-style: normal;
  font-weight: 400;
  font-stretch: 100%;
  src: url('/fonts/roboto-serif-v13-latin_latin-ext-regular.woff2') format('woff2');
}
@font-face {
  font-display: optional;
  font-family: 'Roboto Serif';
  font-style: normal;
  font-weight: 500;
  font-stretch: 100%;
  src: url('/fonts/roboto-serif-v13-latin_latin-ext-500.woff2') format('woff2');
}
@font-face {
  font-display: optional;
  font-family: 'Roboto Serif';
  font-style: normal;
  font-weight: 600;
  font-stretch: 100%;
  src: url('/fonts/roboto-serif-v13-latin_latin-ext-600.woff2') format('woff2');
}
@font-face {
  font-display: optional;
  font-family: 'Roboto Serif';
  font-style: normal;
  font-weight: 700;
  font-stretch: 100%;
  src: url('/fonts/roboto-serif-v13-latin_latin-ext-700.woff2') format('woff2');
}
@font-face {
  font-display: optional;
  font-family: 'Roboto Serif';
  font-style: normal;
  font-weight: 800;
  font-stretch: 100%;
  src: url('/fonts/roboto-serif-v13-latin_latin-ext-800.woff2') format('woff2');
}
  </style>
  <link rel="preload" as="font" href="/fonts/roboto-serif-v13-latin_latin-ext-regular.woff2" crossorigin="anonymous" fetchpriority="high">
  <link rel="preload" as="font" href="/fonts/roboto-serif-v13-latin_latin-ext-800.woff2" crossorigin="anonymous" fetchpriority="high">
  
  {% comment %}
    CSS
  {% endcomment %}
  <link
    rel="preload"
    href="{{  '/css/style.css' | url }}"
    as="style"
    fetchpriority="high"
    />
  <link
    rel="stylesheet"
    href="{{  '/css/style.css' | url }}"
    media="all" />

    {% comment %}
      Sitemap
    {% endcomment %}
  <link rel="canonical" href="{{ meta.url }}{{ page.url }}" />
  <link
    rel="sitemap"
    type="application/xml"
    title="Sitemap for {{ meta.siteName }}"
    href="{{ '/sitemap.xml' | url }}" />
  <link
    rel="alternate"
    type="application/rss+xml"
    title="RSS Feed for {{ meta.siteName }}"
    href="{{ '/feed.xml' | url }}" />

    {% comment %}
      Favicon
    {% endcomment %}
  <link
    rel="shortcut icon"
    href="{{ '/favicon/favicon.ico' | url }}"
    sizes="any" />

  {% comment %}
    Open Graph
  {% endcomment %}
  <meta property="og:type" content="{{ type }}" />
  <meta property="og:locale" content="{{ meta.language }}" />
  <meta property="og:title" content="{{ pageTitle }}" />
  <meta property="og:description" content="{{ pageDescription }}" />
  <meta property="og:url" content="{{ meta.url }}{{ page.url }}" />

    {% comment %}
      Facebook
    {% endcomment %}
  <meta property="fb:admins" content="{{ meta.facebookUsername }}" />
  
    {% comment %}
      100% privacy-first analytics
    {% endcomment %}
<script data-collect-dnt="true" async defer src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
</head>