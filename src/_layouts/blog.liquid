---
title: "Blog"
description: "Here are my posts"
keyword: "test"
type: "website"
---

<!DOCTYPE html>
<html lang="en">
  {% include "head-website.liquid" %}
  <!-- Start Body -->
  <body>
    {% include "nav.liquid" %}
    <main id="main-content">
      <div class="content" cms-edit="source">
        {{ content }}
      </div>
      {%- if collections.tagList.size > 0 -%}
        <div class="all-tags">
          {%- for tag in collections.tagList -%}
            <a href="/tags/{{ tag | slugify }}/" class="post-tag">{{ tag }}</a>
          {%- endfor -%}
        </div>
      {%- endif -%}
      <ul class="list-posts">
        {%- for post in posts -%}
          <li class="posts">
            <h2>
              <a href="{{ post.url }}" cms-edit="source">{{ post.data.title }}</a>
            </h2>
            <p cms-edit="source">{{ post.data.description }}</p>
            <small class="info">
              <time datetime="{{ post.date }}">{{ post.date | readableDate }}</time>&nbsp;&nbsp;&ndash;&nbsp;
              {{ post.content | timeToRead }}&nbsp;to&nbsp;read
            </small>
            {%- assign hasTags = false -%}
            {%- for tag in post.data.tags -%}{%- unless tag == 'post' -%}{%- assign hasTags = true -%}{%- endunless -%}{%- endfor -%}
            {%- if hasTags -%}
              <div class="post-tags">
                {%- for tag in post.data.tags -%}
                  {%- unless tag == 'post' -%}
                    <a href="/tags/{{ tag | slugify }}/" class="post-tag">{{ tag }}</a>
                  {%- endunless -%}
                {%- endfor -%}
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </main>

    <paginate>
      {% if pagination.href.previous or pagination.href.next %}
        <ul class="paginate">
          {% if pagination.href.next %}
            <li class="paginate-prev">
              <a href="{{ pagination.href.next }}" aria-label="Older posts">
                <span class="paginate-label">← Older</span>
                <span class="paginate-title">Older posts</span>
              </a>
            </li>
          {% endif %}
          {% if pagination.href.previous %}
            <li class="paginate-next">
              <a href="{{ pagination.href.previous }}" aria-label="Newer posts">
                <span class="paginate-label">Newer →</span>
                <span class="paginate-title">Newer posts</span>
              </a>
            </li>
          {% endif %}
        </ul>
      {% endif %}
    </paginate>
    {% include "footer.liquid" %}
  </body>
<!-- End Body -->
</html>