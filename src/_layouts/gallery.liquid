---
title: Photos
description: A gallery of photographs from the blog
keyword: gallery
type: website
---
<!DOCTYPE html>
<html lang="en">
  {% include "head-website.liquid" %}
  <!-- Start Body -->
  <body>
    {% include "nav.liquid" %}
    <main data-pagefind-body>
      <h1>{{ title }}</h1>
      {%- assign imgs = collections.galleryImages -%}
      {%- if imgs and imgs.size > 0 -%}
        <div class="gallery-grid">
          {%- for img in imgs -%}
            <div class="gallery-item"
                 data-pswp-src="{{ img.src }}"
                 data-pswp-width="{{ img.width }}"
                 data-pswp-height="{{ img.height }}"
                 data-pswp-thumb="{{ img.thumb }}"
                 data-pswp-alt="{{ img.alt }}"
                 data-pswp-caption="{{ img.caption }}">
              <img src="{{ img.thumb }}" alt="{{ img.alt }}" loading="lazy">
              <button class="gallery-info-btn" aria-label="Photo info">ⓘ</button>
              <div class="gallery-info-tooltip">
                {%- if img.camera != "" -%}<span>Camera: {{ img.camera }}</span>{%- endif -%}
                {%- if img.lens != "" -%}<span>Lens: {{ img.lens }}</span>{%- endif -%}
                {%- if img.film != "" -%}<span>Film: {{ img.film }}</span>{%- endif -%}
                {%- if img.iso != "" -%}<span>ISO {{ img.iso }}</span>{%- endif -%}
                <a href="{{ img.postUrl }}">View post</a>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        <p>No photos yet.</p>
      {%- endif -%}
    </main>
    {% include "footer.liquid" %}
  </body>
  <script type="module">
    (async () => {
      const els = document.querySelectorAll('.gallery-item[data-pswp-src]');
      if (els.length === 0) return;

      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = 'https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe.css';
      document.head.appendChild(link);

      const items = Array.from(els).map(el => ({
        src: el.dataset.pswpSrc,
        width: parseInt(el.dataset.pswpWidth),
        height: parseInt(el.dataset.pswpHeight),
        thumb: el.dataset.pswpThumb,
        alt: el.dataset.pswpAlt || '',
        caption: el.dataset.pswpCaption || ''
      }));

      const { default: PhotoSwipeLightbox } = await import('https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe-lightbox.esm.min.js');

      const lightbox = new PhotoSwipeLightbox({
        dataSource: items,
        pswpModule: () => import('https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe.esm.min.js'),
        bgOpacity: 0.92,
        showHideAnimationType: 'fade',
        zoom: false,
      });

      lightbox.on('uiRegister', function () {
        lightbox.pswp.ui.registerElement({
          name: 'filmstrip',
          order: 17,
          isButton: false,
          appendTo: 'root',
          onInit: (el, pswp) => {
            el.className = 'pswp__filmstrip';
            items.forEach((item, i) => {
              const btn = document.createElement('button');
              btn.className = 'pswp__filmstrip-thumb';
              btn.setAttribute('aria-label', item.alt || `Photo ${i + 1}`);
              const img = document.createElement('img');
              img.src = item.thumb || item.src;
              img.alt = '';
              img.loading = 'lazy';
              btn.appendChild(img);
              btn.addEventListener('click', () => pswp.goTo(i));
              el.appendChild(btn);
            });

            const updateActive = () => {
              el.querySelectorAll('.pswp__filmstrip-thumb').forEach((btn, i) => {
                btn.classList.toggle('active', i === pswp.currIndex);
              });
              const active = el.querySelector('.pswp__filmstrip-thumb.active');
              if (active) active.scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' });
            };

            pswp.on('change', updateActive);
            pswp.on('afterInit', updateActive);
          }
        });

        lightbox.pswp.ui.registerElement({
          name: 'lightbox-caption',
          order: 9,
          isButton: false,
          appendTo: 'wrapper',
          onInit: (el, pswp) => {
            el.className = 'pswp__caption-text';
            const update = () => { el.textContent = items[pswp.currIndex]?.caption || ''; };
            pswp.on('change', update);
            pswp.on('afterInit', update);
          }
        });
      });

      lightbox.init();

      els.forEach((el, i) => {
        el.addEventListener('click', () => {
          if (el.classList.contains('info-open')) {
            el.classList.remove('info-open');
            return;
          }
          lightbox.loadAndOpen(i);
        });
      });

      document.querySelectorAll('.gallery-info-btn').forEach(btn => {
        btn.addEventListener('click', e => {
          e.stopPropagation();
          const item = btn.closest('.gallery-item');
          const opening = !item.classList.contains('info-open');
          document.querySelectorAll('.gallery-item.info-open').forEach(el => el.classList.remove('info-open'));
          if (opening) item.classList.add('info-open');
        });
      });

      document.querySelectorAll('.gallery-info-tooltip').forEach(tip => {
        tip.addEventListener('click', e => e.stopPropagation());
      });
    })();
  </script>
<!-- End Body -->
</html>
