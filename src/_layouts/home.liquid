---
title: Home page
description: Index page for the website
keyword: home
type: website
---
<!DOCTYPE html>
<html lang="en">
  {% include "head-website.liquid" %}
  <!-- Start Body -->
  <body>
    {% include "nav.liquid" %}
    <main data-pagefind-body>
      <div class="content" cms-edit="source">
        {{ content }}
      </div>
      {%- assign recentPosts = collections.post | reverse | slice: 0, 3 -%}
      {%- if recentPosts and recentPosts.size > 0 -%}
        <h2 class="font-bold mb-2">Recent Posts</h2>
        <div class="recent-posts flex flex-col gap-3 mb-3">
          {%- for post in recentPosts -%}
            <div class="flex items-start gap-3">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="icon shrink-0 mt-1"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                <path d="M8 9h8" /><path d="M8 13h6" /><path d="M9 17h6" /><rect x="5" y="3" width="14" height="18" rx="2" />
              </svg>
              <div>
                <a href="{{ post.url }}" cms-edit="source">{{ post.data.title }}</a>
                {% if post.data.description %}
                  <span class="post-description block text-sm" cms-edit="source">{{ post.data.description }}</span>
                {% endif %}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </main>
    {% include "footer.liquid" %}
  </body>
<!-- End Body -->
</html>