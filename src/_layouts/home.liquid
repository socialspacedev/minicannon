---
title: Home page
description: Index page for the website
keyword: home
type: website
---
<!DOCTYPE html>
<html lang="en">
  {% include "head-website.liquid" %}
  <!-- Start Body -->
  <body>
    {% include "nav.liquid" %}
    <main id="main-content" data-pagefind-body>
      <div class="content" cms-edit="source">
        {{ content }}
      </div>
      {%- assign recentPosts = collections.post | reverse | slice: 0, 5 -%}
      {%- assign latestPhotoPost = collections.photography | reverse | first -%}
      <div class="home-grid">
        {%- if latestPhotoPost and latestPhotoPost.data.thumbnail -%}
          <a href="/photos.html" class="home-photo" aria-label="Browse the photo gallery">
            <img src="{{ latestPhotoPost.data.thumbnail }}" alt="Latest photograph from {{ latestPhotoPost.data.title }}" loading="lazy">
          </a>
        {%- endif -%}
        {%- if recentPosts and recentPosts.size > 0 -%}
          <div class="home-posts">
            <h2 class="font-bold mb-2">Recent Posts</h2>
            <div class="recent-posts flex flex-col gap-2">
              {%- for post in recentPosts -%}
                <a href="{{ post.url }}" class="flex items-center gap-3" cms-edit="source">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="icon shrink-0"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    fill="none"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                    <path d="M8 9h8" /><path d="M8 13h6" /><path d="M9 17h6" /><rect x="5" y="3" width="14" height="18" rx="2" />
                  </svg>
                  <span class="post-title">{{ post.data.title }}</span>
                </a>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </main>
    {% include "footer.liquid" %}
  </body>
<!-- End Body -->
</html>