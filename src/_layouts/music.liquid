---
title: Music
description: Posts about music — Vinyl Vibes events, album notes, and tributes
keyword: music
type: website
---
<!DOCTYPE html>
<html lang="en">
  {% include "head-website.liquid" %}
  <body>
    {% include "nav.liquid" %}
    <main id="main-content" data-pagefind-body>
      <h1>{{ title }}</h1>
      {%- assign posts = collections.musicPosts -%}
      {%- if posts and posts.size > 0 -%}
        {%- assign remainder = posts.size | modulo: 3 -%}
        <div class="music-grid">
          {%- for post in posts -%}
            <div class="music-item">
              <a class="music-item__link" href="{{ post.url | url }}" aria-label="{{ post.title }}">
                <img src="{{ post.thumb }}" alt="" loading="lazy">
                <span class="music-item__title">{{ post.title }}</span>
              </a>
              {%- if post.bandcamp_embed -%}
                <button class="music-item__play"
                        type="button"
                        data-bandcamp="{{ post.bandcamp_embed }}"
                        data-title="{{ post.title }}"
                        data-url="{{ post.url | url }}"
                        aria-label="Play {{ post.title }}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
                </button>
              {%- endif -%}
            </div>
          {%- endfor -%}
          {%- if remainder == 2 -%}
            <a class="music-item music-item--more" href="/tags/music/" aria-label="More music posts">
              <span>More music<br><span aria-hidden="true">→</span></span>
            </a>
          {%- endif -%}
        </div>
      {%- else -%}
        <p>No music posts yet.</p>
      {%- endif -%}
    </main>
    <dialog id="bandcamp-modal" class="bc-modal" aria-label="Music player">
      <button class="bc-modal__close" type="button" aria-label="Close player">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      <iframe class="bc-modal__embed" title="Bandcamp player" seamless></iframe>
      <a class="bc-modal__post-link" href="#">View post →</a>
    </dialog>
    {% include "footer.liquid" %}
  </body>
  <script type="module" src="/js/music.js"></script>
</html>
